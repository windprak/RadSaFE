Bootstrap: docker
From: python:3.11-slim

%post
    # Update and install system dependencies
    apt-get update && apt-get install -y \
        git \
        build-essential \
        wget \
        curl \
        && rm -rf /var/lib/apt/lists/*
    
    # Install Python packages for RAG pipeline
    pip install --no-cache-dir \
        torch==2.1.0 \
        transformers==4.36.0 \
        huggingface_hub==0.19.4 \
        sentence-transformers==2.3.1 \
        faiss-cpu==1.7.4 \
        tiktoken==0.5.2 \
        openai==1.6.1 \
        numpy==1.24.3 \
        pandas==2.0.3 \
        tqdm==4.66.1 \
        scikit-learn==1.3.2 \
        bert-score==0.3.13 \
        aiohttp==3.9.1

%environment
    # Use $TMPDIR for cache and temporary files
    export TMPDIR=${TMPDIR:-/tmp}
    export APPTAINER_CACHEDIR=${TMPDIR}/apptainer_cache
    export APPTAINER_TMPDIR=${TMPDIR}/apptainer_tmp
    export SINGULARITY_CACHEDIR=${TMPDIR}/apptainer_cache
    export SINGULARITY_TMPDIR=${TMPDIR}/apptainer_tmp
    export HF_HOME=${TMPDIR}/huggingface
    export TRANSFORMERS_CACHE=${HF_HOME}/transformers
    export HF_DATASETS_CACHE=${HF_HOME}/datasets

%runscript
    exec python3 "$@"

%help
    Apptainer container for RadioRAG Phase 2 - Retrieval and Context Construction
    
    Includes:
    - PyTorch 2.1.0
    - Transformers 4.36.0
    - Sentence-Transformers 2.2.2 (for BGE embeddings)
    - FAISS (CPU version)
    - tiktoken (for token counting)
    - OpenAI API client
    
    Usage:
        apptainer exec rag_environment.sif python3 script.py
